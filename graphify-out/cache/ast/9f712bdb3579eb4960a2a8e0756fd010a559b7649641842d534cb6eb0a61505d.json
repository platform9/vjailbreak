                const vcenterHeader = (\n                      <ListSubheader key={`vc-${vcenterName}`} sx={{ fontWeight: 700 }}>\n                        <Box sx={{ display: 'flex', alignItems: 'center' }}>\n                          <VMwareLogoImg src={vmwareLogo} alt=\"VMware\" />\n                          {vcenterName}\n                        </Box>\n                      </ListSubheader>\n                    )\n\n                    Object.entries(datacenters).forEach(([datacenterName, clusters]) => {\n                      const filteredClusters = term\n                        ? clusters.filter((cluster) => {\n                            const clusterName = cluster.displayName?.toLowerCase() || ''\n                            return (\n                              clusterName.includes(term) ||\n                              vcenterName.toLowerCase().includes(term) ||\n                              datacenterName.toLowerCase().includes(term)\n                            )\n                          })\n                        : clusters\n\n                      if (filteredClusters.length > 0) {\n                        if (!vcenterHasMatches) {\n                          items.push(vcenterHeader)\n                          vcenterHasMatches = true\n                        }\n                        items.push(\n                          <ListSubheader\n                            key={`dc-${credName}-${datacenterName}`}\n                            sx={{ fontWeight: 600, pl: 4 }}\n                          >\n                            <Box sx={{ display: 'flex', alignItems: 'center' }}>\n                              <CdsIconWrapper>\n                                {/* eslint-disable-next-line @typescript-eslint/ban-ts-comment */}\n                                {/* @ts-ignore */}\n                                <cds-icon shape=\"building\" size=\"md\" solid></cds-icon>\n                              </CdsIconWrapper>\n                              {datacenterName}\n                            </Box>\n                          </ListSubheader>\n                        )\n                        filteredClusters.forEach((cluster) => {\n                          items.push(\n                            <MenuItem key={cluster.id} value={cluster.id} sx={{ pl: 7 }}>\n                              <Box sx={{ display: 'flex', alignItems: 'center' }}>\n                                <CdsIconWrapper>\n                                  {/* eslint-disable-next-line @typescript-eslint/ban-ts-comment */}\n                                  {/* @ts-ignore */}\n                                  <cds-icon shape=\"cluster\" size=\"md\"></cds-icon>\n                                </CdsIconWrapper>\n                                {cluster.displayName}\n                              </Box>\n                            </MenuItem>\n                          )\n                        })\n                      }\n                    })\n                  })\n\n                  if (items.length === 0) {\n                    return <MenuItem disabled>No matching clusters found</MenuItem>\n                  }\n                  return items\n                })", "is_member_call": false, "source_file": "/Users/omkard/Documents/goworkspace/src/github.com/platform9/vjailbreak/ui/src/features/migration/SourceDestinationClusterSelection.tsx", "source_location": "L265"}, {"caller_nid": "migration_sourcedestinationclusterselection_sourcedestinationclusterselection", "callee": "map", "is_member_call": true, "source_file": "/Users/omkard/Documents/goworkspace/src/github.com/platform9/vjailbreak/ui/src/features/migration/SourceDestinationClusterSelection.tsx", "source_location": "L470"}]}