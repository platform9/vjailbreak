# Mark generated protobuf files as generated code
# This tells GitHub/reviewers to collapse these files by default
*.pb.go linguist-generated=true
*.pb.gw.go linguist-generated=true
*_grpc.pb.go linguist-generated=true

# Force Unix line endings for shell scripts — prevents CRLF breaking shebangs
# on guests with old Bash (SUSE 11, RHEL 5, etc.)
*.sh text eol=lf
*.bash text eol=lf
